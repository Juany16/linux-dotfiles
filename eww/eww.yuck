  )
)

;; Apps
(defwidget apps []
  (box :class "padre" :space-evenly false :orientation "v"
    (box :class "cuerpo" :orientation "h" :spacing 10 :halign "center" :valing "center" :space-evenly false
      (button :class "botones" :hexpand "false" :onclick "kitty -e nvim" "")
      (button :class "botones" :hexpand "false" :onclick "sqlitebrowser" " 󰆼 ")
    )
    (box :class "cuerpo" :orientation "h" :spacing 10 :halign "center" :valing "center" :space-evenly false
      (button :class "botones" :hexpand "false" :onclick "flatpak run com.valvesoftware.Steam" "  ")
      (button :class "botones" :hexpand "false" :onclick "spotify" "  ")
    )
  )
)

;; To-Do List
(defwidget to-do []
  (box :class "padre" :space-evenly false :orientation "v"
    (box :class "encabezado" :space-evenly false
      ;;(label :text "  Daily List" :class "titulo")
      ;;(button :class "salir" :onclick "eww open todo --toggle" " ")
      (button :class "titulo" :onclick "eww open todo --toggle" "  Daily List")
    )
    (box :class "to-do" :space-evenly false :orientation "v" 
      (label :text todo-list)
    )
  )
)

;; Calendario
(defwidget time [] 
    (box :class "date-container" :orientation "h" :space-evenly false ;;:halign "fill"
      (label :text "${completeday}" :class "fecha")
    )
)

(defwidget cal []
  (box :class "cal-box"
       :orientation "v"
       :space-evenly false
    (calendar :class "cal"
              :day {calendar_day ?: "1"}
              :month {calendar_month ?: "1"}
              :year {calendar_year ?: "2023"}
    )
  )
)

;; Clima
(defwidget clima []
  (box :class "clima" :space-evenly false :orientation "v"
    (box :class "cuerpo" :orientation "v" :halign "center" :valing "center" :space-evenly false
      (label :text infoClima)
    )
  )
)

(defwidget climaD []
  (box :class "climaDs" :space-evenly false :orientation "v"
    (box :class "cuerpo" :orientation "v" :halign "fill" :valing "center" :space-evenly false
      (label :text "Proximos días" :class "tituloClimaD")
      (separador)
      (label :text infoClimaDs)
    )
  )
)

(defwidget date []
  (box :class "date"
       :orientation "v"
       :space-evenly false
       :spacing 5
    (time2)
    (clima)
    (cal) 
    (climaD)
  )
)

;; Reloj de Bloqueo
(defwidget time2 []
    (box :class "date-container2" :orientation "v" :space-evenly false :halign "center"
      (label :class "hora-bloqueo" :text "${hora}")
      (label :class "fecha-bloqueo" :text "${fecha}")
      ;;(label :class "fecha-bloqueo" :text "${infoClima}")
    )
)

;; VENTANAS

;; Reloj
(defwindow reloj
  ;;:geometry (geometry :x "0px" :y "200px" :anchor "top center")
  :geometry (geometry :x "-10px" :y "40px" :anchor "top right")
  :wm-ignore true
(time2))

;; Calendario
(defwindow date
  :geometry (geometry :x "-10px" :y "40px" :anchor "top right" :width "305px")
  :wm-ignore true
(date))

;; Menu apagado
(defwindow power
  :geometry (geometry :x "-10px" :y "40px" :anchor "top right")
  :wm-ignore true
(menu))

;; Ajustes
(defwindow ajustes
  ;;:geometry (geometry :x "-305px" :y "40px" :anchor "top right")
  :geometry (geometry :x "-10px" :y "40px" :anchor "top right" :max-height "100px" :width "305px")
  :wm-ignore true
(media_widget))

;; To-Do
(defwindow todo
  :geometry (geometry :x "10" :y "40px" :anchor "top left")
  :wm-ignore true
(to-do))

;; Notis
(defwindow notis
  :geometry (geometry :x "-10" :y "40px" :anchor "top right" :width "305px")
  :stacking "overlay"
  :exclusive true
  :focusable false
  :windowtype "dialog"
  :wm-ignore true
(notification_center))
