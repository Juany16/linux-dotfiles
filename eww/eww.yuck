;; VARIABLES

(defpoll date :interval "1s" "date '+%d %b, %I:%M %p'")
(defpoll completeday :interval "1s" "date '+%a. %d / %m  |  %H:%M'")

(defpoll lithour :interval "30m" "date +%H")
(defpoll litmin :interval "30s" "date +%M")

(defpoll hora :interval "1s" "date '+%H:%M'")
(defpoll fecha :interval "1s" "date '+%a. %d / %m'")

(defpoll calendar_day :interval "10h" "date '+%d'")
(defpoll calendar_month :interval "10h" "date '+%m'")
(defpoll calendar_year :interval "10h" "date '+%Y'")

;; Clima Var
(defpoll infoClima :interval "1h" "~/.config/eww/scripts/climaActual.sh")
(defpoll infoClimaDs :interval "1h" "~/.config/eww/scripts/climaDias.sh")

;; To-Do Var
(defpoll todo-list :interval "10s" "~/.config/eww/scripts/tareas.sh")

;; Notis Var
(defpoll notis :interval "10s" "~/.config/eww/scripts/notis.sh")

;; Music polls
(deflisten media_info 
    :initial '{"player": "", "status": "Stopped", "title": "No Media", "artist": "", "cover": ""}'
    "~/.config/eww/scripts/musicaSpotify.sh")

;; Poll untuk Notifikasi (Dunst) - UPDATED
(defpoll notification_count :interval "2s"
  :initial "0"
  `dunstctl count history || echo 0`)

(defpoll notification_history :interval "500ms"
  :initial "[]"
  `~/.config/eww/scripts/notificaciones.sh`)

;; WIDGETS

;; Separador
(defwidget separador []
  (box :class "separador" :hexpand true :width "350px"))

;; Items de Notificaciones
(defwidget notification_item [appname summary id icon_path]
  (box :class "notification-item"
       :orientation "h"
       :spacing 5
       :space-evenly false
    
    ;; Ikon Notifikasi
    (box :class "notification-icon-container"
         :visible {icon_path != "" && icon_path != "null"}
      (label :text " " :style "font-size: 24px;"))
    
    ;; Teks Notifikasi
    (box :class "notification-text-container"
         :orientation "v"
         :halign "start"
         :valign "center"
         :hexpand true
         :space-evenly false
      (label :class "notification-appname"
             :text appname
             :xalign 0
             :limit-width 35)
      (label :class "notification-summary"
             :text summary
             :xalign 0
             :wrap true
             :limit-width 35))
    
    ;; Button close yang berfungsi
    ;;(button :class "notification-close-btn"
            ;;:onclick "dunstctl history-rm ${id} && eww update notification_history=$(~/.config/eww/scripts/notificaciones.sh)"
      ;;(label :text "✕"))
  )
)

;; Centro de Notificaciones
(defwidget notification_center []
  (box :class "notification-center-container"
       :orientation "v"
       :space-evenly false
       :spacing 2

    ;; Header Notifikasi - FIXED
    (box :class "notification-header"
         :orientation "h"
         :space-evenly false
         :hexpand true
      (label :class "notification-header-title"
             :text "Notificaciones "
             :halign "start"
             :hexpand true)
      (button :class "botonesNA" :halign "fill" :hexpand "false" :onclick "dunstctl set-paused false" " ")
      (button :class "botonesND" :halign "fill" :hexpand "false" :onclick "dunstctl set-paused true" " ")
      (button :class "botonBN" :onclick "dunstctl history-clear && eww update notification_history='[]'" :xalign 1 "󰆴")
    )
    
    ;; Daftar Notifikasi (dengan scroll)
    (scroll :class "notification-list-scroll"
            ;;:height 597
            :height 368
            :spacing 5
            :vscroll true
            :hscroll false
      (box :class "notification-list"
           :orientation "v"
           :spacing 8
           :valign {notification_count == 0 ? "center" : "start"}
           :vexpand true
           ;; Loop melalui hasil script
           (for notification in notification_history
             (notification_item
                 :appname {notification.appname}
                 :summary {notification.summary}
                 :id {notification.id}
                 :icon_path {notification.icon}
             )
           )
           ;; Footer di DALAM scroll - tampil saat tidak ada notifikasi
           (box :class "notification-footer"
                :halign "center"
                :valign "center"
                :vexpand true
                :visible {notification_count == 0}
             (label :text "Sin notificaciones nuevas"))
      )
    )
))

;; Reproductor
(defwidget media_widget []
  (box :class "media-widget-container"
       :orientation "v"
       :space-evenly false
       :spacing 10
    (box  :class "cuerpo" :orientation "h" :space-evenly false :spacing 10
          (time)
;;          (button :class "botonApagar" :xalign 0.5 :onclick "poweroff" "")
;;          (button :class "botonReiniciar" :xalign 0.5 :onclick "reboot" "")
;;          (button :class "botonSesion" :xalign 0.5 :onclick "bspc quit" "󰍃")
          (button :class "botonBloquear" :xalign 0.5 :onclick "~/.config/Scripts/blocki3lock.sh" "")
          (button :class "botonCerrar" :xalign 0.5 :onclick "eww open ajustes --toggle" "")
    )
    (separador)
    (box  :class "cuerpo" :orientation "h" :space-evenly false :spacing 10
          ;;(clima)
          (button :class "botonDia" :xalign 0.5 
                  :onclick "notify-send 'Modo Noche' 'Filtro activado' && xsct 2800 & eww close ajustes"
                  :onrightclick  "notify-send 'Modo Noche' 'Filtro desactivado' && xsct 6500 & eww close ajustes" "")
;;          (button :class "botonNoche" :xalign 0.5 
;;                  :onclick "notify-send 'Modo Noche' 'Filtro activado' && xsct 2800 & eww close ajustes" "󰃛")
;;          (button :class "botonAndroid" :xalign 0.5 :onclick "scrcpy" "")
;;          (button :class "botonMatar" :xalign 0.5 :onclick "pkill scrcpy" "")
;;          (button :class "botonKde" :xalign 0.5 :onclick "kdeconnect-indicator" "")
;;          (button :class "botonMatar" :xalign 0.5 :onclick "pkill kdeconnect-indi" :onrightclick "pkill kdeconnectd" "")
;;          (button :class "botones" :xalign 0.5 
;;                  :onclick "~/.config/eww/scripts/xsetA.sh & eww close ajustes" "󰍹")
          (button :class "botones" :xalign 0.5 
                  :onclick "~/.config/eww/scripts/xsetD.sh & eww close ajustes"
                  :onrightclick  "~/.config/eww/scripts/xsetA.sh & eww close ajustes" "󰶐")
          (button :class "botonVol" :xalign 0.5 :onclick "pavucontrol & eww close ajustes" "")
          (button :class "botonTerminal" :hexpand "false" 
                  :onclick "bspc rule -a kitty -o state=floating center=on rectangle=850x550+100+100 && kitty ~/ & 
                  eww close ajustes" "")
          (button :class "botones" :hexpand "false" 
                  :onclick "bspc rule -a kitty -o state=floating center=on rectangle=850x550+100+100 && kitty -e ranger ~/ & 
                  eww close ajustes" "")
          (button :class "botonTerminal" :hexpand "false" 
                  :onclick "bspc rule -a kitty -o state=floating center=on rectangle=850x550+100+100 && kitty -e nvim & 
                  eww close ajustes" "")
          (button :class "botonBlocPags" :hexpand "false" 
                  :onclick "bspc rule -a kitty -o state=floating center=on rectangle=850x550+100+100 && 
                  kitty -e ~/.config/Scripts/BloqueoPaginas.sh & eww close ajustes" 
                  :onrightclick "bspc rule -a kitty -o state=floating center=on rectangle=850x550+100+100 && 
                  kitty -e ~/.config/Scripts/DesbloqueoPaginas.sh & eww close ajustes" "󰂭")
    )

    ;; Cover Art
    ;;(box :class "media-cover-widget"
         ;;:style {media_info.cover != "" ? "background-image: url('${media_info.cover}'); 
         ;;background-size: contain; background-repeat: no-repeat; background-position: center;" : "background-image: none;"}
         ;;:visible {media_info.cover != ""})
    
    ;; Media Info
    (box :class "media-widget-info"
         :orientation "v"  
         :space-evenly false
         :spacing 10
      
      ;; Label section
      (box :orientation "v"
           :space-evenly false
           :hexpand true
           :halign "center"
        (label :class "media-widget-name"
               :text {media_info.player}
               :visible {media_info.player != ""}
               :xalign 0.5)
        (label :class "media-widget-title"
               :text {media_info.title}
               :limit-width 35
               :xalign 0.5)
        (label :class "media-widget-artist"
               :text {media_info.artist}
               :limit-width 35
               :xalign 0.5))
      
      ;; Controls
    (box :class "media-widget-controls" :halign "fill" :spacing 5
        (button :class "media-widget-btn"
                :onclick "playerctl -p ${media_info.player} previous"
          (box :width 30 :height 30 :halign "center" :valign "center"
            (label :text "󰒮" :style "font-size: 28px;")))
        
        (button :class "media-widget-btn-play"
                :onclick "playerctl -p ${media_info.player} play-pause"
          (box :width 30 :height 30 :halign "center" :valign "center"
            (label :text {media_info.status == "Playing" ? "󰏤" : "󰐊"}                       :style "font-size: 32px;")))
        
        (button :class "media-widget-btn"
                :onclick "playerctl -p ${media_info.player} next"
          (box :width 30 :height 30 :halign "center" :valign "center"
            (label :text "󰒭" :style "font-size: 28px;"))))

    )
    (notification_center)
    ))

;; Menu apagado
(defwidget menu []
  (box :class "padre" :space-evenly true :orientation "v"
    (box :class "cuerpo" :orientation "h" :spacing 10 :halign "center" :valing "center" :space-evenly true
      (button :class "botonApagar" :xalign 0.5 :onclick "poweroff" "")
      (button :class "botonReiniciar" :xalign 0.5 :onclick "reboot" "")
      (button :class "botonSesion" :xalign 0.5 :onclick "bspc quit" "󰍃")
      (button :class "botonBloquear" :xalign 0.5 :onclick "~/.config/Scripts/blocki3lock.sh" "")
      (button :class "botonCerrar" :xalign 0.5 :onclick "eww open ajustes --toggle" "")
    )
  )
)

